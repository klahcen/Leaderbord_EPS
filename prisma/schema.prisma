generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PROFESSOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum KnowledgeDomain {
  PROCEDURALE
  CONCEPTUELLE
  COMPORTEMENTALE
}

enum ActivityFamily {
  ATHLETISME
  SPORTS_COLLECTIFS
  GYMNASTIQUE
}

enum SubActivity {
  COURSE_VITESSE
  COURSE_HAIES
  COURSE_RELAIS
  COURSE_ENDURANCE
  SAUT_LONGUEUR
  SAUT_HAUTEUR
  TRIPLE_SAUT
  LANCER_POIDS
  LANCER_DISQUE
  LANCER_JAVELOT
  FOOTBALL
  BASKETBALL
  HANDBALL
  RUGBY
  VOLLEYBALL
  BADMINTON
  GYMNASTIQUE_SOL
}

enum AthletismeGroup {
  COURSES
  SAUTS
  LANCERS
}

enum SportsCollectifsType {
  MARQUAGE_DEMARQUAGE
  SPORTS_RENVOI
}

enum EvaluationCriteria {
  HABILETE_MOTRICE
  COMPORTEMENT_MOTEUR
  CAPACITE_INDIVIDUELLE
  CAPACITE_COLLECTIVE
  CAPACITE_GYMNASTIQUE
  CONNAISSANCE_CONCEPTUELLE
  CONNAISSANCE_COMPORTEMENTALE
}

enum EvaluationDefinition {
  PRODUIT
  PERFORMANCE
  PRODUIT_COMPORTEMENT_PHYSIQUE
  CONNAISSANCES_CONCEPTUELLES
  ABSENCE_TENU_ARBITRAGE
}

enum EvaluationTool {
  CHRONOMETRE_DECAMETRE
  GRILLE_OBSERVATION
  QUESTIONS_REPONSES
  OBSERVATION_DIRECTE
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(PROFESSOR)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  progressLogs ProgressLog[]
}

model SchoolClass {
  id        String    @id @default(cuid())
  name      String    @unique
  code      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  students  Student[]

  @@map("Class")
}

model Student {
  id           String        @id @default(cuid())
  name         String
  studentCode  String        @unique
  classId      String?
  schoolClass  SchoolClass?  @relation(fields: [classId], references: [id], onDelete: SetNull)
  age          Int?
  gender       Gender?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  progressLogs ProgressLog[]
}

model ProgressLog {
  id              String               @id @default(cuid())
  studentId       String
  student         Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professorId     String
  professor       User                 @relation(fields: [professorId], references: [id])

  family          ActivityFamily
  subActivity     SubActivity
  knowledgeDomain KnowledgeDomain
  criteria        EvaluationCriteria
  definition      EvaluationDefinition
  tool            EvaluationTool
  iacMax          Int
  score           Float
  semester        Int                  @default(1)
  notes           String?
  recordedAt      DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([studentId])
  @@index([professorId])
  @@index([family])
  @@index([subActivity])
  @@index([knowledgeDomain])
  @@index([recordedAt])
}
