DATABASE_URL="postgresql://user:password@localhost:5432/pe_dashboard"
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# AUTH_URL — set in production to your public URL (e.g. https://leaderbordeps-production.up.railway.app)
# In dev, omit AUTH_URL; trustHost picks up localhost automatically
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Railway: add PostgreSQL plugin, then set DATABASE_URL, AUTH_SECRET, ANTHROPIC_API_KEY, AUTH_URL
# Build: npm run build  |  Start: npm run railway:start  (or: make railway-build && make railway-start)
